@model RealMadridWeb.Models.Staff

@{
    ViewData["Title"] = "Add Staff";
}

<h1>Add New Staff Member</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label">Full Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Role" class="form-label">Role / Position</label>
                <input asp-for="Role" class="form-control" placeholder="e.g., Manager, Assistant Coach, Physio" />
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TeamId" class="form-label">Assigned Team</label>
                <select asp-for="TeamId" class="form-control" asp-items="ViewBag.TeamId"></select>
            </div>

            <button type="submit" class="btn btn-success">Save Staff Member</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>