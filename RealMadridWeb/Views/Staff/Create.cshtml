@model RealMadridWeb.Models.Staff

@{
    ViewData["Title"] = "Create Staff";
}

<div class="row justify-content-center">
    <div class="col-md-6 card p-4 shadow-sm my-5 border-0 rounded-3" style="background: #ffffff;">
        <h2 class="fw-bold mb-4" style="color: #0f1c3f;">Add Technical Staff Member</h2>
        
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label fw-semibold text-secondary">Full Name</label>
                <input asp-for="Name" class="form-control" style="border-radius: 8px;" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="form-label fw-semibold text-secondary">Profile Image URL</label>
                <input asp-for="ImageUrl" class="form-control" style="border-radius: 8px;" placeholder="https://..." />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Role" class="form-label fw-semibold text-secondary">Role</label>
                <input asp-for="Role" class="form-control" style="border-radius: 8px;" />
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="TeamId" class="form-label fw-semibold text-secondary">Assigned Team</label>
                <select asp-for="TeamId" class="form-control" asp-items="ViewBag.TeamId" style="border-radius: 8px;"></select>
                <span asp-validation-for="TeamId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100 py-2">Add Member</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2" style="border-radius: 8px;">Cancel</a>
            </div>
        </form>
    </div>
</div>