@model RealMadridWeb.Models.Player

@{
    ViewData["Title"] = "Edit Player Profile";
}

<div class="row justify-content-center">
    <div class="col-md-6 card p-4 shadow-sm my-5 border-0 rounded-3" style="background: #ffffff;">
        <h2 class="fw-bold mb-4" style="color: #0f1c3f;">Edit Player Profile</h2>
        
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TeamId" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label fw-semibold text-secondary">Full Name</label>
                <input asp-for="Name" class="form-control" style="border-radius: 8px;" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Position" class="form-label fw-semibold text-secondary">Squad Position</label>
                <select asp-for="Position" class="form-control" style="border-radius: 8px;">
                    <option value="Goalkeeper">Goalkeeper</option>
                    <option value="Defender">Defender</option>
                    <option value="Midfielder">Midfielder</option>
                    <option value="Forward">Forward</option>
                </select>
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ShirtNumber" class="form-label fw-semibold text-secondary">Shirt Number</label>
                <input asp-for="ShirtNumber" type="number" min="1" max="99" class="form-control" style="border-radius: 8px;" />
                <span asp-validation-for="ShirtNumber" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="form-label fw-semibold text-secondary">Player Photo URL</label>
                <input asp-for="ImageUrl" class="form-control" style="border-radius: 8px;" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <hr class="my-4">
            <h5 class="fw-bold mb-3 text-primary">Season Statistics</h5>
            
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label asp-for="Goals" class="form-label small fw-semibold text-secondary">Goals Scored</label>
                    <input asp-for="Goals" type="number" min="0" class="form-control" style="border-radius: 8px;" />
                    <span asp-validation-for="Goals" class="text-danger"></span>
                </div>
                <div class="col-6">
                    <label asp-for="Assists" class="form-label small fw-semibold text-secondary">Assists Provided</label>
                    <input asp-for="Assists" type="number" min="0" class="form-control" style="border-radius: 8px;" />
                    <span asp-validation-for="Assists" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100 py-2">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2" style="border-radius: 8px;">Cancel</a>
            </div>
        </form>
    </div>
</div>