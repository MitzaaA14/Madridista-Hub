@model RealMadridWeb.DTOs.Sponsor.CreateSponsorDto

@{
    ViewData["Title"] = "Add Sponsor";
}

<div class="row justify-content-center">
    <div class="col-md-6 card p-4 shadow-sm my-5 border-0 rounded-3" style="background: #ffffff;">
        <h2 class="fw-bold mb-4" style="color: #0f1c3f;">Add New Corporate Partner</h2>
        
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label fw-semibold text-secondary">Sponsor Company Name</label>
                <input asp-for="Name" class="form-control" style="border-radius: 8px;" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Type" class="form-label fw-semibold text-secondary">Partnership Tier</label>
                <select asp-for="Type" class="form-control" style="border-radius: 8px;">
                    <option value="Main Sponsor">Main Sponsor (e.g., Emirates)</option>
                    <option value="Global Partner">Global Partner (e.g., Adidas)</option>
                    <option value="Official Partner">Official Regional Partner</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="LogoUrl" class="form-label fw-semibold text-secondary">Brand Logo URL</label>
                <input asp-for="LogoUrl" class="form-control" style="border-radius: 8px;" placeholder="https://..." />
                <span asp-validation-for="LogoUrl" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100 py-2">Add Brand</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2" style="border-radius: 8px;">Cancel</a>
            </div>
        </form>
    </div>
</div>