@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Madridista Hub</title>
    
    <link rel="icon" type="image/png" href="~/images/logo2.png?v=3" sizes="32x32" />
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --rm-dark: #0f1c3f;
            --rm-gold: #c19d55;
            --rm-gold-hover: #a38243;
            --rm-light: #f4f6f9;
        }
        body {
            background-color: var(--rm-light);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .navbar-custom {
            background-color: var(--rm-dark) !important;
            border-bottom: 4px solid var(--rm-gold);
            padding: 0.8rem 1rem;
        }
        .navbar-custom .navbar-brand {
            color: #ffffff !important;
            font-size: 1.3rem;
            letter-spacing: 0.5px;
        }
        .navbar-custom .nav-link {
            color: rgba(255, 255, 255, 0.85) !important;
            font-weight: 500;
            transition: color 0.2s ease;
        }
        .navbar-custom .nav-link:hover {
            color: var(--rm-gold) !important;
        }
        .btn-gold {
            background-color: var(--rm-gold);
            color: #ffffff !important;
            font-weight: 600;
            border-radius: 8px;
            border: none;
            transition: all 0.2s ease;
        }
        .btn-gold:hover {
            background-color: var(--rm-gold-hover);
            transform: translateY(-1px);
        }
        .footer-custom {
            background-color: var(--rm-dark);
            color: rgba(255, 255, 255, 0.7);
            border-top: 4px solid var(--rm-gold);
            padding: 25px 0;
            font-size: 0.9rem;
        }
    </style>
</head>
<body class="d-flex flex-column h-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-custom shadow mb-4">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center fw-bold text-uppercase" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="Real Madrid" width="40" height="40" class="d-inline-block align-text-top me-2" style="object-fit: contain;">
                    MADRIDISTA HUB
                </a>
                <button class="navbar-toggler text-white border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-3">
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Players" asp-action="Index">Squad</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Teams" asp-action="Index">Teams</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Matches" asp-action="Index">Schedule</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Staff" asp-action="Index">Staff</a></li>
                        <li class="nav-item"><a class="nav-link px-3" asp-controller="Sponsors" asp-action="Index">Sponsors</a></li>
                        <li class="nav-item"><a class="nav-link px-3 fw-bold" style="color: #64ffda !important;" asp-controller="Home" asp-action="LiveStats">Live Stats</a></li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold me-2" asp-controller="Profile" asp-action="Index">👤 @User.Identity?.Name</a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="form-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3 rounded-3" style="font-weight:600;">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link me-3" asp-controller="Account" asp-action="Register">Register</a></li>
                            <li class="nav-item"><a class="btn btn-sm btn-gold px-4 py-2" asp-controller="Account" asp-action="Login">Login</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-shrink-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom text-center mt-auto">
        <div class="container">
            <span class="fw-bold" style="color: var(--rm-gold);">HALA MADRID</span><br>
            <small>&copy; 2026 - Madridista Hub - Premium Club Portal</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>