@model RealMadridWeb.DTOs.PlayerCreateDto

@{
    ViewData["Title"] = "Add New Player";
}

<div class="row justify-content-center">
    <div class="col-md-6 card p-4 shadow-sm my-5 border-0 rounded-3" style="background: #ffffff;">
        <h2 class="fw-bold mb-4" style="color: #0f1c3f;">Add New Player</h2>
        
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label fw-semibold text-secondary">Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Kylian Mbappé" style="border-radius: 8px;" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Position" class="form-label fw-semibold text-secondary">Squad Position</label>
                <select asp-for="Position" class="form-control" style="border-radius: 8px;">
                    <option value="">-- Select Position --</option>
                    <option value="Goalkeeper">Goalkeeper</option>
                    <option value="Defender">Defender</option>
                    <option value="Midfielder">Midfielder</option>
                    <option value="Forward">Forward</option>
                </select>
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ShirtNumber" class="form-label fw-semibold text-secondary">Shirt Number</label>
                <input asp-for="ShirtNumber" type="number" min="1" max="99" class="form-control" style="border-radius: 8px;" />
                <span asp-validation-for="ShirtNumber" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TeamId" class="form-label fw-semibold text-secondary">Assigned Team</label>
                <select asp-for="TeamId" class="form-control" asp-items="ViewBag.TeamId" style="border-radius: 8px;">
                    <option value="">-- Select Team Squad --</option>
                </select>
                <span asp-validation-for="TeamId" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="ImageUrl" class="form-label fw-semibold text-secondary">Player Photo URL</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/photo.png" style="border-radius: 8px;" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <hr class="my-4">
            <h5 class="fw-bold mb-3" style="color: #c19d55;">Initial Season Statistics</h5>
            
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label asp-for="Goals" class="form-label small fw-semibold text-secondary">Goals</label>
                    <input asp-for="Goals" type="number" value="0" min="0" class="form-control" style="border-radius: 8px;" />
                    <span asp-validation-for="Goals" class="text-danger"></span>
                </div>
                <div class="col-6">
                    <label asp-for="Assists" class="form-label small fw-semibold text-secondary">Assists</label>
                    <input asp-for="Assists" type="number" value="0" min="0" class="form-control" style="border-radius: 8px;" />
                    <span asp-validation-for="Assists" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100 py-2" style="border-radius: 8px; background-color: #0f1c3f; border: none;">Create Player</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2" style="border-radius: 8px;">Cancel</a>
            </div>
        </form>
    </div>
</div>