@model IEnumerable<RealMadridWeb.Models.Player>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 py-3">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <p class="text-muted fs-5">No players found in this category.</p>
        </div>
    }
    else
    {
        @foreach (var player in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm overflow-hidden position-relative group" style="border-radius: 12px; background: #ffffff;">
                    
                    <div class="position-absolute top-0 end-0 m-3 bg-dark text-white fw-bold d-flex align-items-center justify-content-center shadow-sm" style="width: 38px; height: 38px; border-radius: 50%; border: 2px solid #c19d55; z-index: 2; font-size: 0.95rem;">
                        #@player.ShirtNumber
                    </div>

                    <div style="height: 260px; background-color: #f8f9fa;" class="d-flex align-items-end justify-content-center overflow-hidden">
                        @if (!string.IsNullOrEmpty(player.ImageUrl))
                        {
                            <img src="@player.ImageUrl" class="w-100 h-100" style="object-fit: cover; object-position: top; transition: transform 0.2s ease;" alt="@player.Name">
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-secondary text-white fs-1 fw-bold">@player.Name.Substring(0, 1)</div>
                        }
                    </div>

                    <div class="card-body p-3 text-center">
                        <h5 class="fw-bold text-dark m-0 mb-1 text-truncate" style="font-size: 1.05rem;">@player.Name</h5>
                        <span class="badge bg-light text-secondary border text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">@player.Position</span>
                        
                        <div class="row g-0 mt-3 pt-2 border-top text-center">
                            <div class="col-6 border-end">
                                <small class="text-muted d-block text-uppercase" style="font-size: 0.6rem; font-weight: 600;">Goals</small>
                                <span class="fw-bold text-dark" style="font-size: 0.95rem;">@player.Goals</span>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block text-uppercase" style="font-size: 0.6rem; font-weight: 600;">Assists</small>
                                <span class="fw-bold text-dark" style="font-size: 0.95rem;">@player.Assists</span>
                            </div>
                        </div>
                    </div>

                    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                    {
                        <div class="card-footer bg-white border-0 d-flex justify-content-around pb-3 pt-0">
                            <a asp-controller="Players" asp-action="Edit" asp-route-id="@player.Id" class="btn btn-sm btn-outline-secondary px-3" style="border-radius: 6px; font-size: 0.75rem; font-weight: 600;">Edit</a>
                            <a asp-controller="Players" asp-action="Delete" asp-route-id="@player.Id" class="btn btn-sm btn-outline-danger px-3" style="border-radius: 6px; font-size: 0.75rem; font-weight: 600;">Remove</a>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>