@model IEnumerable<RealMadridWeb.Models.Player>

@{
    ViewData["Title"] = "Real Madrid Squad";
}

<div class="d-flex justify-content-between align-items-center my-4">
    <h1>Official Squad - Real Madrid</h1>
    <a asp-action="Create" class="btn btn-primary">Add New Player</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Number</th>
            <th>Name</th>
            <th>Team</th>
            <th>Position</th>
            <th>Goals</th>
            <th>Assists</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var player in Model)
        {
            <tr>
                <td><strong>#@player.ShirtNumber</strong></td>
                <td>@player.Name</td>
                <td>@(player.Team != null ? player.Team.Name : "No Team")</td>
                <td>@player.Position</td>
                <td>@player.Goals</td>
                <td>@player.Assists</td>
            </tr>
        }
    </tbody>
</table>