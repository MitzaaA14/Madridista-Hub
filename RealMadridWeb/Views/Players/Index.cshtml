@model IEnumerable<RealMadridWeb.DTOs.PlayerReadDto>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Official Squad";

    var selectedTeamId = Context.Request.Query["teamId"].ToString();

    var filteredPlayers = !string.IsNullOrEmpty(selectedTeamId)
        ? Model.Where(p => p.TeamId == int.Parse(selectedTeamId))
        : Model;

    var female = filteredPlayers.Where(p => !string.IsNullOrEmpty(p.TeamName) &&
        (p.TeamName.Contains("Female", StringComparison.OrdinalIgnoreCase) ||
         p.TeamName.Contains("Women", StringComparison.OrdinalIgnoreCase) ||
         p.TeamName.Contains("Femenino", StringComparison.OrdinalIgnoreCase) ||
         p.TeamName.Contains("Girls", StringComparison.OrdinalIgnoreCase)));

    var academy = filteredPlayers.Where(p => !string.IsNullOrEmpty(p.TeamName) &&
        (p.TeamName.Contains("Academy", StringComparison.OrdinalIgnoreCase) ||
         p.TeamName.Contains("Castilla", StringComparison.OrdinalIgnoreCase) ||
         p.TeamName.Contains("Juvenil", StringComparison.OrdinalIgnoreCase) ||
         p.TeamName.Contains("B Team", StringComparison.OrdinalIgnoreCase)));

    var firstTeam = filteredPlayers.Where(p => string.IsNullOrEmpty(p.TeamName) ||
        (!academy.Any(a => a.Id == p.Id) && !female.Any(f => f.Id == p.Id)));

    var allPositions = Model.Select(p => p.Position).Distinct().OrderBy(p => p).ToList();
}

<div class="d-flex justify-content-between align-items-center my-4">
    <h1 class="fw-bold" style="color: #0f1c3f;">Real Madrid Squad</h1>
    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Add New Player</a>
    }
</div>

@if (!string.IsNullOrEmpty(selectedTeamId))
{
    <div class="mb-4">
        <a asp-controller="Teams" asp-action="Index" class="btn btn-sm btn-outline-secondary px-3 py-2 fw-semibold" style="border-radius: 8px;">&larr; Back to Teams</a>
    </div>
}


<div class="card border-0 shadow-sm mb-4 p-3" style="border-radius: 12px;">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label fw-semibold small text-uppercase text-muted">Search by name</label>
            <input type="text" id="searchName" class="form-control" placeholder="e.g. Bellingham..." oninput="applyFilters()">
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold small text-uppercase text-muted">Position</label>
            <select id="filterPosition" class="form-select" onchange="applyFilters()">
                <option value="">All positions</option>
                @foreach (var pos in allPositions)
                {
                    <option value="@pos">@pos</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold small text-uppercase text-muted">Sort by</label>
            <select id="sortBy" class="form-select" onchange="applyFilters()">
                <option value="number">Shirt Number</option>
                <option value="name">Name</option>
                <option value="goals">Goals</option>
                <option value="assists">Assists</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">Reset</button>
        </div>
    </div>
</div>

<ul class="nav nav-pills mb-4 justify-content-center" id="squadTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active px-4 fw-semibold" id="first-team-tab" data-bs-toggle="tab" data-bs-target="#first-team" type="button" role="tab">First Team</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link px-4 fw-semibold" id="academy-tab" data-bs-toggle="tab" data-bs-target="#academy" type="button" role="tab">Castilla / Academy</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link px-4 fw-semibold" id="female-tab" data-bs-toggle="tab" data-bs-target="#female" type="button" role="tab">Women's Team</button>
    </li>
</ul>

<div class="tab-content" id="squadTabsContent">
    <div class="tab-pane fade show active" id="first-team" role="tabpanel">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 py-3" id="grid-first-team">
            @foreach (var player in firstTeam)
            {
                <div class="col player-card"
                     data-name="@player.Name.ToLower()"
                     data-position="@player.Position"
                     data-number="@player.ShirtNumber"
                     data-goals="@player.Goals"
                     data-assists="@player.Assists">
                    @await Html.PartialAsync("_PlayerCard", player)
                </div>
            }
        </div>
        <div id="empty-first-team" class="text-center py-5 d-none"><p class="text-muted fs-5">No players match the filters.</p></div>
    </div>
    <div class="tab-pane fade" id="academy" role="tabpanel">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 py-3" id="grid-academy">
            @foreach (var player in academy)
            {
                <div class="col player-card"
                     data-name="@player.Name.ToLower()"
                     data-position="@player.Position"
                     data-number="@player.ShirtNumber"
                     data-goals="@player.Goals"
                     data-assists="@player.Assists">
                    @await Html.PartialAsync("_PlayerCard", player)
                </div>
            }
        </div>
        <div id="empty-academy" class="text-center py-5 d-none"><p class="text-muted fs-5">No players match the filters.</p></div>
    </div>
    <div class="tab-pane fade" id="female" role="tabpanel">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 py-3" id="grid-female">
            @foreach (var player in female)
            {
                <div class="col player-card"
                     data-name="@player.Name.ToLower()"
                     data-position="@player.Position"
                     data-number="@player.ShirtNumber"
                     data-goals="@player.Goals"
                     data-assists="@player.Assists">
                    @await Html.PartialAsync("_PlayerCard", player)
                </div>
            }
        </div>
        <div id="empty-female" class="text-center py-5 d-none"><p class="text-muted fs-5">No players match the filters.</p></div>
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: #0f1c3f;
        border: 1px solid #0f1c3f;
        margin: 0 5px;
        border-radius: 8px;
        transition: all 0.2s ease;
    }
    .nav-pills .nav-link.active {
        background-color: #0f1c3f !important;
        color: #ffffff !important;
        border-color: #0f1c3f;
    }
    .nav-pills .nav-link:hover:not(.active) {
        background-color: rgba(15, 28, 63, 0.05);
    }
</style>

<script>
    function applyFilters() {
        const name = document.getElementById('searchName').value.toLowerCase();
        const position = document.getElementById('filterPosition').value;
        const sortBy = document.getElementById('sortBy').value;

        const grids = ['first-team', 'academy', 'female'];

        grids.forEach(gridId => {
            const grid = document.getElementById('grid-' + gridId);
            const emptyMsg = document.getElementById('empty-' + gridId);
            const cards = Array.from(grid.querySelectorAll('.player-card'));

            // Filter
            let visible = cards.filter(card => {
                const matchName = card.dataset.name.includes(name);
                const matchPos = !position || card.dataset.position === position;
                return matchName && matchPos;
            });

            let hidden = cards.filter(card => !visible.includes(card));

            // Sort visible cards
            visible.sort((a, b) => {
                if (sortBy === 'number') return parseInt(a.dataset.number) - parseInt(b.dataset.number);
                if (sortBy === 'name') return a.dataset.name.localeCompare(b.dataset.name);
                if (sortBy === 'goals') return parseInt(b.dataset.goals) - parseInt(a.dataset.goals);
                if (sortBy === 'assists') return parseInt(b.dataset.assists) - parseInt(a.dataset.assists);
            });

            // Reorder DOM
            visible.forEach(card => { card.classList.remove('d-none'); grid.appendChild(card); });
            hidden.forEach(card => card.classList.add('d-none'));

            // Show/hide empty message
            emptyMsg.classList.toggle('d-none', visible.length > 0);
        });
    }

    function resetFilters() {
        document.getElementById('searchName').value = '';
        document.getElementById('filterPosition').value = '';
        document.getElementById('sortBy').value = 'number';
        applyFilters();
    }

    // Sort by number on load
    document.addEventListener('DOMContentLoaded', applyFilters);
</script>
