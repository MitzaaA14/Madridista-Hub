@model RealMadridWeb.DTOs.PlayerReadDto
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
    var isFav = ViewData[$"fav_{Model.Id}"] as bool? ?? false;
}

<div class="card h-100 border-0 shadow-sm overflow-hidden position-relative" style="border-radius: 12px; background: #ffffff;">
    <div class="position-absolute top-0 end-0 m-3 bg-dark text-white fw-bold d-flex align-items-center justify-content-center shadow-sm"
         style="width: 38px; height: 38px; border-radius: 50%; border: 2px solid #c19d55; z-index: 2; font-size: 0.95rem;">
        #@Model.ShirtNumber
    </div>
    <div style="height: 260px; background-color: #f8f9fa;" class="d-flex align-items-end justify-content-center overflow-hidden">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="w-100 h-100" style="object-fit: cover; object-position: top;" alt="@Model.Name">
        }
        else
        {
            <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-secondary text-white fs-1 fw-bold">@Model.Name.Substring(0, 1)</div>
        }
    </div>
    <div class="card-body p-3 text-center">
        <h5 class="fw-bold text-dark m-0 mb-1 text-truncate" style="font-size: 1.05rem;">@Model.Name</h5>
        <span class="badge bg-light text-secondary border text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">@Model.Position</span>
        <div class="row g-0 mt-3 pt-2 border-top text-center">
            <div class="col-6 border-end">
                <small class="text-muted d-block text-uppercase" style="font-size: 0.6rem; font-weight: 600;">Goals</small>
                <span class="fw-bold text-dark" style="font-size: 0.95rem;">@Model.Goals</span>
            </div>
            <div class="col-6">
                <small class="text-muted d-block text-uppercase" style="font-size: 0.6rem; font-weight: 600;">Assists</small>
                <span class="fw-bold text-dark" style="font-size: 0.95rem;">@Model.Assists</span>
            </div>
        </div>
    </div>
    <div class="card-footer bg-white border-0 pb-3 pt-0">
        @if (SignInManager.IsSignedIn(User))
        {
            <div class="d-flex justify-content-center mb-2">
                <form asp-controller="Profile" asp-action="@(isFav ? "RemoveFavoritePlayer" : "AddFavoritePlayer")" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="playerId" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit" class="btn btn-sm w-100 px-3"
                            style="border-radius:6px; font-size:0.78rem; font-weight:600;
                                   background:@(isFav ? "#fff3cd" : "#f8f9fa");
                                   border: 1px solid @(isFav ? "#c19d55" : "#dee2e6");
                                   color: @(isFav ? "#856404" : "#6c757d");">
                        @(isFav ? "Favourite" : "Add to Favourites")
                    </button>
                </form>
            </div>
        }
        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
        {
            <div class="d-flex justify-content-around">
                <a asp-controller="Players" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary px-3" style="border-radius: 6px; font-size: 0.75rem; font-weight: 600;">Edit</a>
                <a asp-controller="Players" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger px-3" style="border-radius: 6px; font-size: 0.75rem; font-weight: 600;">Remove</a>
            </div>
        }
    </div>
</div>
