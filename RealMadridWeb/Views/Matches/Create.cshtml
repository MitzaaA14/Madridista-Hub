@model RealMadridWeb.DTOs.Match.CreateMatchDto

@{
    ViewData["Title"] = "Schedule New Match";
}

<div class="row justify-content-center">
    <div class="col-md-6 card p-4 shadow-sm my-5 border-0 rounded-3" style="background: #ffffff;">
        <h2 class="fw-bold mb-4" style="color: #0f1c3f;">Schedule New Match</h2>
        
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="TeamId" class="form-label fw-semibold text-secondary">Our Club Squad</label>
                <select asp-for="TeamId" class="form-control" asp-items="ViewBag.TeamId" style="border-radius: 8px;">
                    <option value="">-- Select Which Team Plays --</option>
                </select>
                <span asp-validation-for="TeamId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Venue" class="form-label fw-semibold text-secondary">Match Location Type</label>
                <select asp-for="Venue" class="form-control" style="border-radius: 8px;">
                    <option value="Home">Home (Real Madrid is Host)</option>
                    <option value="Away">Away (Real Madrid is Guest)</option>
                </select>
                <span asp-validation-for="Venue" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Opponent" class="form-label fw-semibold text-secondary">Opponent Name</label>
                <input asp-for="Opponent" class="form-control" placeholder="e.g. Barcelona, Atletico Madrid" style="border-radius: 8px;" />
                <span asp-validation-for="Opponent" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="League" class="form-label fw-semibold text-secondary">League / Competition</label>
                <input asp-for="League" class="form-control" placeholder="e.g. La Liga, Champions League" style="border-radius: 8px;" />
                <span asp-validation-for="League" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Stadium" class="form-label fw-semibold text-secondary">Stadium / Arena</label>
                <input asp-for="Stadium" class="form-control" placeholder="e.g. Santiago Bernabéu" style="border-radius: 8px;" />
                <span asp-validation-for="Stadium" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="HomeTeamLogoUrl" class="form-label fw-semibold text-secondary">Home Team Logo URL</label>
                <input asp-for="HomeTeamLogoUrl" class="form-control" placeholder="https://..." style="border-radius: 8px;" />
                <span asp-validation-for="HomeTeamLogoUrl" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AwayTeamLogoUrl" class="form-label fw-semibold text-secondary">Away Team Logo URL</label>
                <input asp-for="AwayTeamLogoUrl" class="form-control" placeholder="https://..." style="border-radius: 8px;" />
                <span asp-validation-for="AwayTeamLogoUrl" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Date" class="form-label fw-semibold text-secondary">Match Date & Time</label>
                <input asp-for="Date" type="datetime-local" class="form-control" style="border-radius: 8px;" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100 py-2" style="border-radius: 8px; background-color: #0f1c3f; border: none;">Save Match</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2" style="border-radius: 8px;">Cancel</a>
            </div>
        </form>
    </div>
</div>