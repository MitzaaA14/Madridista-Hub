@model RealMadridWeb.Models.Match
@using Microsoft.AspNetCore.Identity
@using RealMadridWeb.Models
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Match Details";
    var playerMatches = ViewData["PlayerMatches"] as List<PlayerMatch> ?? new List<PlayerMatch>();
    var comments      = ViewData["Comments"] as List<MatchComment> ?? new List<MatchComment>();
    var isAdmin       = SignInManager.IsSignedIn(User) && User.IsInRole("Admin");
    var isLoggedIn    = SignInManager.IsSignedIn(User);
    var isWatchlisted = ViewData["IsWatchlisted"] as bool? ?? false;
    var currentUserId = ViewData["CurrentUserId"] as string ?? "";
}

<div class="my-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back to Fixtures</a>

    <!-- Match card -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px; overflow: hidden;">
        <div class="p-4 text-center" style="background: #0f1c3f;">
            <div class="d-flex justify-content-center gap-2 mb-3">
                <span class="badge bg-warning text-dark text-uppercase px-2 py-1">@Model.League</span>
                <span class="badge bg-secondary text-uppercase px-2 py-1">@Model.Venue</span>
                @if (Model.IsFinished)
                {
                    <span class="badge bg-success text-uppercase px-2 py-1">FT</span>
                }
                else
                {
                    <span class="badge bg-info text-uppercase px-2 py-1">Upcoming</span>
                }
            </div>

            <div class="d-flex align-items-center justify-content-center gap-4 text-white">
                <div class="text-center" style="min-width: 120px;">
                    @if (!string.IsNullOrEmpty(Model.HomeTeamLogoUrl))
                    {
                        <img src="@Model.HomeTeamLogoUrl" width="60" height="60" style="object-fit: contain;" />
                    }
                    else
                    {
                        <div class="mx-auto bg-white text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width:60px;height:60px;">RM</div>
                    }
                    <div class="fw-bold mt-2">@(Model.Venue == "Home" ? "Real Madrid" : Model.Opponent)</div>
                </div>

                <div class="text-center px-3">
                    @if (Model.IsFinished)
                    {
                        <span class="fw-bold display-5">@Model.HomeScore - @Model.AwayScore</span>
                    }
                    else
                    {
                        <span class="fw-bold fs-3 text-muted">VS</span>
                    }
                </div>

                <div class="text-center" style="min-width: 120px;">
                    @if (!string.IsNullOrEmpty(Model.AwayTeamLogoUrl))
                    {
                        <img src="@Model.AwayTeamLogoUrl" width="60" height="60" style="object-fit: contain;" />
                    }
                    else
                    {
                        <div class="mx-auto bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width:60px;height:60px;">OPP</div>
                    }
                    <div class="fw-bold mt-2">@(Model.Venue == "Home" ? Model.Opponent : "Real Madrid")</div>
                </div>
            </div>

            <div class="text-white-50 mt-3 small">
                @Model.Date.ToString("dd MMM yyyy - HH:mm") · @Model.Stadium
            </div>

            <!-- Buton Watchlist -->
            @if (isLoggedIn)
            {
                <div class="mt-3">
                    <form asp-controller="Profile" asp-action="@(isWatchlisted ? "RemoveFromWatchlist" : "AddToWatchlist")" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="matchId" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="@Url.Action("Details","Matches", new { id = Model.Id })" />
                        <button type="submit" class="btn btn-sm px-4 py-2 fw-semibold"
                                style="background:@(isWatchlisted ? "#c19d55" : "rgba(255,255,255,.12)");
                                       color:#fff; border:1px solid @(isWatchlisted ? "#c19d55" : "rgba(255,255,255,.4)");
                                       border-radius:8px;">
                            @(isWatchlisted ? "📅 În Watchlist" : "📅 Adaugă în Watchlist")
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>

    <!-- Squad -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3" style="color: #0f1c3f;">🏟️ Squad in this Match</h5>

            @if (!playerMatches.Any())
            {
                <p class="text-muted fst-italic">No players added to this match yet.</p>
            }
            else
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Player</th>
                            <th class="text-center">Minutes Played</th>
                            <th class="text-center">Rating</th>
                            @if (isAdmin) { <th class="text-center">Actions</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pm in playerMatches)
                        {
                            <tr>
                                <td>
                                    <strong>@pm.Player?.Name</strong>
                                    <span class="text-muted small ms-2">@pm.Player?.Position</span>
                                </td>
                                <td class="text-center">@pm.MinutesPlayed'</td>
                                <td class="text-center">
                                    <span class="badge @(pm.Rating >= 7 ? "bg-success" : pm.Rating >= 5 ? "bg-warning text-dark" : "bg-danger")">
                                        @pm.Rating.ToString("0.0")
                                    </span>
                                </td>
                                @if (isAdmin)
                                {
                                    <td class="text-center">
                                        <form asp-action="RemovePlayer" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="playerMatchId" value="@pm.Id" />
                                            <input type="hidden" name="matchId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Remove this player from the match?')">Remove</button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- Admin: Add player -->
    @if (isAdmin)
    {
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3" style="color: #0f1c3f;">➕ Add Player to Match</h5>
                <form asp-action="AddPlayer" method="post" class="row g-3 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="matchId" value="@Model.Id" />
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Player</label>
                        <select name="playerId" class="form-select" required asp-items="@(ViewData["PlayerId"] as SelectList)">
                            <option value="">-- Select Player --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Minutes Played</label>
                        <input type="number" name="minutesPlayed" class="form-control" min="1" max="120" value="90" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Rating (0-10)</label>
                        <input type="number" name="rating" class="form-control" min="0" max="10" step="0.1" value="7.0" required />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Add</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <!-- ── COMENTARII ────────────────────────────────────────────────── -->
    <div class="card border-0 shadow-sm" style="border-radius: 15px;">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-4" style="color: #0f1c3f;">💬 Comentarii (@comments.Count)</h5>

            @if (TempData["CommentError"] != null)
            {
                <div class="alert alert-danger py-2">@TempData["CommentError"]</div>
            }

            <!-- Form comentariu nou -->
            @if (isLoggedIn)
            {
                <form asp-controller="Profile" asp-action="AddComment" method="post" class="mb-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="matchId" value="@Model.Id" />
                    <div class="d-flex gap-2">
                        <textarea name="content" class="form-control" rows="2"
                                  placeholder="Lasă un comentariu despre acest meci..."
                                  maxlength="500" required
                                  style="border-radius:10px; resize:none;"></textarea>
                        <button type="submit" class="btn align-self-end px-4 fw-semibold"
                                style="background:#0f1c3f; color:#fff; border-radius:10px; white-space:nowrap;">
                            Trimite
                        </button>
                    </div>
                </form>
            }
            else
            {
                <div class="alert alert-light border mb-4 py-2 small">
                    <a asp-controller="Account" asp-action="Login">Loghează-te</a> pentru a lăsa un comentariu.
                </div>
            }

            <!-- Lista comentarii -->
            @if (!comments.Any())
            {
                <p class="text-muted fst-italic text-center py-3">Fii primul care comentează acest meci!</p>
            }
            else
            {
                @foreach (var c in comments)
                {
                    <div class="d-flex gap-3 mb-3 align-items-start">
                        <!-- Avatar -->
                        <div class="d-flex align-items-center justify-content-center rounded-circle fw-bold text-white flex-shrink-0"
                             style="width:38px; height:38px; background:#0f1c3f; font-size:.9rem;">
                            @(c.User?.Email?.Substring(0,1).ToUpper() ?? "?")
                        </div>
                        <div class="flex-grow-1 p-3 rounded-3" style="background:#f8f9fa;">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-semibold small" style="color:#0f1c3f;">@c.User?.Email?.Split('@')[0]</span>
                                <small class="text-muted">@c.CreatedAt.ToString("dd MMM, HH:mm")</small>
                            </div>
                            <div>@c.Content</div>
                        </div>
                        <!-- Ștergere (doar userul propriu) -->
                        @if (c.UserId == currentUserId)
                        {
                            <form asp-controller="Profile" asp-action="DeleteComment" method="post" class="align-self-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="commentId" value="@c.Id" />
                                <input type="hidden" name="matchId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary"
                                        style="border-radius:6px; font-size:.7rem;"
                                        onclick="return confirm('Ștergi comentariul?')">🗑</button>
                            </form>
                        }
                    </div>
                }
            }
        </div>
    </div>

</div>
