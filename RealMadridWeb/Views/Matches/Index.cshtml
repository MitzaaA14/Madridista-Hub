@model IEnumerable<RealMadridWeb.Models.Match>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Schedule & Results";
    var leagues = Model.Select(m => m.League).Distinct().OrderBy(l => l).ToList();
    var teams = Model.Where(m => m.Team != null).Select(m => m.Team!.Name).Distinct().OrderBy(t => t).ToList();
}

<div class="d-flex justify-content-between align-items-center my-4">
    <h1 class="fw-bold" style="color: #0f1c3f;">Fixtures & Results</h1>
    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Add New Match</a>
    }
</div>

<div class="card border-0 shadow-sm mb-4 p-3" style="border-radius: 12px;">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label fw-semibold small text-uppercase text-muted">Status</label>
            <select id="filterStatus" class="form-select" onchange="applyFilters()">
                <option value="">All</option>
                <option value="upcoming">Upcoming</option>
                <option value="finished">Results</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold small text-uppercase text-muted">League</label>
            <select id="filterLeague" class="form-select" onchange="applyFilters()">
                <option value="">All leagues</option>
                @foreach (var league in leagues)
                {
                    <option value="@league">@league</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold small text-uppercase text-muted">Team</label>
            <select id="filterTeam" class="form-select" onchange="applyFilters()">
                <option value="">All teams</option>
                @foreach (var team in teams)
                {
                    <option value="@team">@team</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold small text-uppercase text-muted">Venue</label>
            <select id="filterVenue" class="form-select" onchange="applyFilters()">
                <option value="">Home & Away</option>
                <option value="Home">Home</option>
                <option value="Away">Away</option>
            </select>
        </div>
        <div class="col-md-1">
            <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">Reset</button>
        </div>
    </div>
</div>

<div id="noResults" class="text-center py-5 d-none">
    <p class="text-muted fs-5">No matches found for the selected filters.</p>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="matchesGrid">
    @foreach (var match in Model)
    {
        <div class="col match-card"
             data-status="@(match.IsFinished ? "finished" : "upcoming")"
             data-league="@match.League"
             data-team="@(match.Team?.Name ?? "")"
             data-venue="@match.Venue">
            <div class="card h-100 border-0 shadow-sm overflow-hidden" style="border-radius: 15px; background: #ffffff;">
                <div class="p-4 text-center bg-light border-bottom">
                    <div class="d-flex justify-content-center gap-1 mb-3">
                        <span class="badge bg-primary text-uppercase px-2 py-1" style="font-size: 0.65rem;">@(match.Team?.Name ?? "Real Madrid")</span>
                        <span class="badge bg-dark text-uppercase px-2 py-1" style="font-size: 0.65rem;">@match.League</span>
                        <span class="badge bg-secondary text-uppercase px-2 py-1" style="font-size: 0.65rem;">@match.Venue</span>
                    </div>

                    <div class="d-flex align-items-center justify-content-center gap-3">
                        <div class="text-center" style="width: 100px;">
                            @if (!string.IsNullOrEmpty(match.HomeTeamLogoUrl))
                            {
                                <img src="@match.HomeTeamLogoUrl" width="50" height="50" style="object-fit: contain;">
                            }
                            else
                            {
                                <div class="mx-auto bg-dark text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 50px; height: 50px;">T1</div>
                            }
                            <small class="d-block fw-bold text-dark mt-1 text-truncate" style="font-size: 0.75rem;">@(match.Venue == "Home" ? "Real Madrid" : match.Opponent)</small>
                        </div>

                        @if (match.IsFinished)
                        {
                            <div class="px-2">
                                <span class="fw-extrabold fs-3 text-dark d-block">@match.HomeScore - @match.AwayScore</span>
                                <span class="badge bg-secondary text-uppercase" style="font-size: 0.55rem;">FT</span>
                            </div>
                        }
                        else
                        {
                            <span class="fw-bold text-muted px-2 fs-5">VS</span>
                        }

                        <div class="text-center" style="width: 100px;">
                            @if (!string.IsNullOrEmpty(match.AwayTeamLogoUrl))
                            {
                                <img src="@match.AwayTeamLogoUrl" width="50" height="50" style="object-fit: contain;">
                            }
                            else
                            {
                                <div class="mx-auto bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 50px; height: 50px;">T2</div>
                            }
                            <small class="d-block fw-bold text-dark mt-1 text-truncate" style="font-size: 0.75rem;">@(match.Venue == "Home" ? match.Opponent : "Real Madrid")</small>
                        </div>
                    </div>

                    <div class="mt-3 pt-2 border-top text-secondary small">
                        <div class="fw-semibold text-dark">@match.Date.ToString("dd MMM yyyy - HH:mm")</div>
                        <div class="text-muted mt-1" style="font-size: 0.75rem;">@match.Stadium</div>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 d-flex justify-content-around py-3">
                    <a asp-action="Details" asp-route-id="@match.Id" class="btn btn-sm btn-outline-primary px-3" style="border-radius: 6px; font-weight: 600;">Squad</a>
                    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@match.Id" class="btn btn-sm btn-outline-secondary px-3" style="border-radius: 6px; font-weight: 600;">Edit / Score</a>
                        <a asp-action="Delete" asp-route-id="@match.Id" class="btn btn-sm btn-outline-danger px-3" style="border-radius: 6px; font-weight: 600;">Remove</a>
                    }
                </div>
            </div>
        </div>
    }
</div>

<script>
    function applyFilters() {
        const status = document.getElementById('filterStatus').value;
        const league = document.getElementById('filterLeague').value;
        const team = document.getElementById('filterTeam').value;
        const venue = document.getElementById('filterVenue').value;

        const cards = document.querySelectorAll('.match-card');
        let visibleCount = 0;

        cards.forEach(card => {
            const matchStatus = !status || card.dataset.status === status;
            const matchLeague = !league || card.dataset.league === league;
            const matchTeam = !team || card.dataset.team === team;
            const matchVenue = !venue || card.dataset.venue === venue;

            if (matchStatus && matchLeague && matchTeam && matchVenue) {
                card.classList.remove('d-none');
                visibleCount++;
            } else {
                card.classList.add('d-none');
            }
        });

        document.getElementById('noResults').classList.toggle('d-none', visibleCount > 0);
    }

    function resetFilters() {
        document.getElementById('filterStatus').value = '';
        document.getElementById('filterLeague').value = '';
        document.getElementById('filterTeam').value = '';
        document.getElementById('filterVenue').value = '';
        applyFilters();
    }
</script>
